{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "860px",
      "wideSize": "1280px"
    },
    "color": {
      "palette": [
        {
          "slug": "white",
          "color": "#FFFFFF",
          "name": "White"
        },
        {
          "slug": "lavender",
          "color": "#F0F2FF",
          "name": "Lavender"
        },
        {
          "slug": "graphite",
          "color": "#111827",
          "name": "Graphite"
        },
        {
          "slug": "graphite-light",
          "color": "#374151",
          "name": "Graphite Light"
        },
        {
          "slug": "orange",
          "color": "#FF6B35",
          "name": "Orange"
        },
        {
          "slug": "orange-soft",
          "color": "#FFF8F5",
          "name": "Orange Soft"
        },
        {
          "slug": "green",
          "color": "#10B981",
          "name": "Green"
        },
        {
          "slug": "border",
          "color": "#E5E7EB",
          "name": "Border"
        },
        {
          "slug": "blue",
          "color": "#3B82F6",
          "name": "Blue"
        },
        {
          "slug": "yellow",
          "color": "#F59E0B",
          "name": "Yellow"
        },
        {
          "slug": "surface",
          "color": "#F9FAFB",
          "name": "Surface"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Plus Jakarta Sans', 'Segoe UI', Tahoma, sans-serif",
          "slug": "jakarta",
          "name": "Plus Jakarta Sans"
        },
        {
          "fontFamily": "Georgia, 'Times New Roman', serif",
          "slug": "serif",
          "name": "Serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "medium",
          "size": "1rem",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "1.25rem",
          "name": "Large"
        },
        {
          "slug": "x-large",
          "size": "1.75rem",
          "name": "Extra Large"
        },
        {
          "slug": "xx-large",
          "size": "2.25rem",
          "name": "2X Large"
        },
        {
          "slug": "huge",
          "size": "clamp(2.2rem, 5vw, 3.25rem)",
          "name": "Huge"
        }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingSizes": [
        {
          "slug": "10",
          "size": "0.5rem",
          "name": "XS"
        },
        {
          "slug": "20",
          "size": "1rem",
          "name": "S"
        },
        {
          "slug": "30",
          "size": "1.5rem",
          "name": "M"
        },
        {
          "slug": "40",
          "size": "2rem",
          "name": "L"
        },
        {
          "slug": "50",
          "size": "3rem",
          "name": "XL"
        },
        {
          "slug": "60",
          "size": "4rem",
          "name": "2XL"
        },
        {
          "slug": "70",
          "size": "5rem",
          "name": "3XL"
        },
        {
          "slug": "80",
          "size": "7rem",
          "name": "4XL"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#FFFFFF",
      "text": "#111827"
    },
    "typography": {
      "fontFamily": "'Plus Jakarta Sans', 'Segoe UI', Tahoma, sans-serif",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "'Plus Jakarta Sans', 'Segoe UI', Tahoma, sans-serif",
          "fontWeight": "800",
          "lineHeight": "1.2",
          "letterSpacing": "-0.02em"
        },
        "color": {
          "text": "#111827"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "clamp(2.2rem, 5vw, 3.25rem)",
          "fontWeight": "900",
          "lineHeight": "1.15",
          "letterSpacing": "-0.03em"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "2.25rem",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "1.75rem",
          "lineHeight": "1.25"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "1.25rem",
          "lineHeight": "1.3"
        }
      },
      "link": {
        "color": {
          "text": "#FF6B35"
        },
        ":hover": {
          "color": {
            "text": "#111827"
          }
        }
      },
      "button": {
        "typography": {
          "fontWeight": "700",
          "fontSize": "0.95rem"
        },
        "border": {
          "radius": "12px"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontSize": "0.9rem",
          "fontWeight": "600"
        }
      },
      "core/button": {
        "border": {
          "radius": "12px"
        }
      }
    }
  }
}